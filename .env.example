# Base PostgreSQL (lecture de schéma + exécution SQL)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Clé API Google (Gemini)
GOOGLE_API_KEY=

# Même rôle que le header n8n x-api-config
API_CONFIG_SECRET=d2e539b6-25b6-4606-a6c2-10a47691179d

# Chemin d’intégration n8n (segment après /webhook/) — identique côté VITE (front)
N8N_WEBHOOK_PATH_SEGMENT=5a2715bd-0b56-4e05-9c24-eb48e13c5d7a
# En-tête de réponse X-Bi-Stream-Version sur POST …/stream (debug / cohérence client)
BI_STREAM_VERSION_HEADER=3

# Optionnel, ex. gemini-3-flash-preview, gemini-3.1-pro-preview
GEMINI_MODEL=gemini-3-flash-preview

PORT=3000

# Nombre de messages d’historique (lignes user+assistant) à recharger pour la discussion continue.
# Moins d’échanges = moins de tokens = réponses en général plus rapides (moins de contexte).
CHAT_HISTORY_MAX_MESSAGES=3

# Cache mémoire du JSON schéma BDD (requête lourde sur information_schema). 0 = toujours recharger.
# Après un changement de structure en base, le cache expire ou redéployez (ou mettez 0 temporairement).
BDD_SCHEMA_CACHE_TTL_SECONDS=300

# Plafond de tours agent (LLM + outils). 40 = défaut ; baisser peut limiter les réponses longues côté durée.
AGENT_RECURSION_LIMIT=40
