# Base PostgreSQL (lecture de schéma + exécution SQL)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Clé API Google (Gemini)
GOOGLE_API_KEY=

# Même rôle que le header n8n x-api-config
API_CONFIG_SECRET=d2e539b6-25b6-4606-a6c2-10a47691179d

# Optionnel, ex. gemini-3-flash-preview, gemini-3.1-pro-preview
GEMINI_MODEL=gemini-3-flash-preview

PORT=3000

# Nombre de messages d’historique (lignes user+assistant) à recharger pour la discussion continue (ex. 3 ou 4)
CHAT_HISTORY_MAX_MESSAGES=4
