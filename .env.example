# Base applicative (IAM, rôles, conversations, n8n_chat_histories_v6, …)
DATABASE_URL=postgresql://user:pass@host:5432/appdb
# Base BI : connexion et tables sont gérées depuis l’interface admin (menu Base BI).

# Migrations (base app uniquement, via scripts/db-exec.cjs + DATABASE_URL) :
#   npm run db:migrate:app
#   (ou : db:migrate:auth, db:migrate:chat, db:migrate:conversations-all)
# Le schéma des tables analytiques (base BI) est géré hors de ce dépôt.

# Clé API Google (Gemini)
GOOGLE_API_KEY=

# Même rôle que le header n8n x-api-config (intégrations type n8n = accès complet BI)
API_CONFIG_SECRET=d2e539b6-25b6-4606-a6c2-10a47691179d

# Authentification JWT (POST /auth/login, en-tête Bearer sur le webhook, gestion rôles /iam)
JWT_SECRET=changer-avec-une-chaine-longue-aleatoire

# Inscription publique POST /auth/register (désactivé par défaut)
# AUTH_PUBLIC_REGISTER=true
# Rôle appliqué aux nouveaux comptes (défaut côté code : user — exécuter migration auth_rbac)
# REGISTER_DEFAULT_ROLE_SLUG=user

# Si true : le webhook BI n’accepte plus x-api-config (n8n) — uniquement Authorization: Bearer
# (recommandé en production)
# WEBHOOK_JWT_ONLY=true

# Création unique du 1er admin si aucun compte n’existe (optionnel)
# BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# BOOTSTRAP_ADMIN_PASSWORD=ChangeMoi-8min

# Chemin d’intégration n8n (segment après /webhook/) — identique côté VITE (front)
N8N_WEBHOOK_PATH_SEGMENT=5a2715bd-0b56-4e05-9c24-eb48e13c5d7a
# En-tête de réponse X-Bi-Stream-Version sur POST …/stream (debug / cohérence client)
BI_STREAM_VERSION_HEADER=3

# Optionnel, ex. gemini-3-flash-preview, gemini-3.1-pro-preview
GEMINI_MODEL=gemini-3-flash-preview

PORT=3000

# Nombre de messages d’historique (lignes user+assistant) à recharger pour la discussion continue.
# Moins d’échanges = moins de tokens = réponses en général plus rapides (moins de contexte).
CHAT_HISTORY_MAX_MESSAGES=3

# Cache mémoire du JSON schéma BDD (requête lourde sur information_schema). 0 = toujours recharger.
# Après un changement de structure en base, le cache expire ou redéployez (ou mettez 0 temporairement).
BDD_SCHEMA_CACHE_TTL_SECONDS=300

# Plafond de tours agent (LLM + outils). 40 = défaut ; baisser peut limiter les réponses longues côté durée.
AGENT_RECURSION_LIMIT=40
